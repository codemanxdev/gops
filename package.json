{
  "name": "gops",
  "displayName": "Gops - Visual Git Toolkit",
  "description": "Visual Git Toolkit for VS Code",
  "version": "0.0.2",
  "publisher": "codemanxdev",
  "repository": {
    "type": "git",
    "url": "https://github.com/codemanxdev/gops.git"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "gitops",
    "git-ui",
    "git-gui",
    "visual-git",
    "source-control",
    "version-control",
    "scm",
    "github",
    "gitlab",
    "repository",
    "commit",
    "branch",
    "merge",
    "rebase",
    "stash",
    "cherry-pick",
    "diff",
    "history",
    "workflow",
    "productivity",
    "gui"
  ],
  "icon": "resources/gops-logo.png",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gops.helloWorld",
        "title": "Gops Hello World"
      },
      {
        "command": "gops.refresh",
        "title": "Refresh Git Ops View",
        "icon": "$(refresh)"
      },
      {
        "command": "gops.pull",
        "title": "Pull Latest Changes",
        "icon": "$(repo-pull)"
      },
      {
        "command": "gops.push",
        "title": "Push Changes",
        "icon": "$(repo-push)"
      },
      {
        "command": "gops.branch",
        "title": "New Branch",
        "icon": "$(git-branch)"
      },
      {
        "command": "gops.branch.current",
        "title": "Create Branch from Current",
        "icon": "$(git-branch)"
      },
      {
        "command": "gops.checkout",
        "title": "Checkout Branch",
        "icon": "$(git-branch)"
      },
      {
        "command": "gops.deleteBranch",
        "title": "Delete Branch",
        "icon": "$(trash)"
      },
      {
        "command": "gops.renameBranch",
        "title": "Rename Branch",
        "icon": "$(edit)"
      },
      {
        "command": "gops.tag",
        "title": "Create Tag",
        "icon": "$(tag)"
      },
      {
        "command": "gops.showDiff",
        "title": "Show Diff",
        "icon": "$(diff)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gopsContainer",
          "title": "Gops",
          "icon": "resources/gops-icon.svg"
        }
      ]
    },
    "views": {
      "gopsContainer": [
        {
          "id": "gitOpsTreeview",
          "name": "Git Ops View",
          "icon": "resources/gops-icon.svg"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "gops.refresh",
          "when": "view == gitOpsTreeview",
          "group": "navigation"
        },
        {
          "command": "gops.pull",
          "when": "view == gitOpsTreeview",
          "group": "navigation"
        },
        {
          "command": "gops.push",
          "when": "view == gitOpsTreeview",
          "group": "navigation"
        },
        {
          "command": "gops.branch.current",
          "when": "view == gitOpsTreeview",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "gops.branch",
          "when": "view == gitOpsTreeview && (viewItem == localBranches || viewItem == localBranches.current)",
          "group": "navigation"
        },
        {
          "command": "gops.checkout",
          "when": "view == gitOpsTreeview && viewItem == localBranches",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vsce:package": "vsce package --no-dependencies",
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "build": "npm run package",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "check-test-types": "tsc -p tsconfig.test.json --noEmit",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test:integration": "vscode-test",
    "test:unit": "vitest",
    "coverage:integration": "c8 npm run test:integration",
    "coverage:unit": "c8 npm run test:unit"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.19",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "c8": "^11.0.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "mocha": "^11.7.5",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "simple-git": "^3.36.0"
  },
  "c8": {
    "reporter": [
      "lcov",
      "text"
    ],
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "**/*.test.ts"
    ]
  }
}
